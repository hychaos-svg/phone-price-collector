{
  "name": "phone-price-collector",
  "version": "2.0.0",
  "description": "手机价格采集系统 - 支持多云部署",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "collect": "node -e \"require('./src/collector').collectAllPrices().then(p => console.log('采集完成:', p.length, '条'))\"",
    "collect:github": "node scripts/github_collect.js",
    "collect:msrp": "node scripts/collect_msrp.js",
    "dev": "node src/index.js",
    "build": "echo 'No build required'"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "exceljs": "^4.4.0",
    "iconv-lite": "^0.6.3",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "@vercel/blob": "^0.24.0"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [
    "phone",
    "price",
    "collector",
    "excel"
  ],
  "license": "MIT"
}
