{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@3",
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/collect",
      "schedule": "0 12 * * *"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
